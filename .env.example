# ================================================================
# FinWise AI — Environment Variables (Firebase Edition)
# Copy to .env.local and fill in your values
# NEVER commit .env.local to Git
# ================================================================

# ── MINIMUM TO RUN (just these 3 for demo) ───────────────────

# NextAuth secret — run: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-32-char-string-here"
NEXTAUTH_URL="http://localhost:3000"

# Anthropic Claude AI — https://console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-api03-your-key-here"

# ── FIREBASE (free — https://firebase.google.com) ────────────
# Step 1: Go to https://console.firebase.google.com
# Step 2: Create project → Add Web App → Copy config
NEXT_PUBLIC_FIREBASE_API_KEY="AIzaSy-your-key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789:web:abc123"

# Step 3: Project Settings → Service Accounts → Generate new private key
# Copy the JSON values below:
FIREBASE_ADMIN_PROJECT_ID="your-project-id"
FIREBASE_ADMIN_CLIENT_EMAIL="firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com"
# Paste private key with \n for newlines:
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ── GOOGLE OAUTH (optional but recommended) ──────────────────
# https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# ── RAZORPAY PAYMENTS (optional) ─────────────────────────────
# https://razorpay.com → Dashboard → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_your_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_secret"

# ── APP CONFIG ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="FinWise AI"

# ── ANALYTICS (optional) ─────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# ================================================================
# QUICK START:
# 1. cp .env.example .env.local
# 2. Fill NEXTAUTH_SECRET + ANTHROPIC_API_KEY + Firebase values
# 3. npm install
# 4. npm run dev
# Done! No database migrations needed — Firebase auto-creates collections
# ================================================================
